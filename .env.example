# === DATABASE ===
POSTGRES_USER=socialdrop
POSTGRES_PASSWORD=socialdrop_secret
POSTGRES_DB=socialdrop
DATABASE_URL=postgresql://socialdrop:socialdrop_secret@localhost:5432/socialdrop

# === REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === APP CONFIG ===
NODE_ENV=development
JWT_SECRET=change_me_in_production_min_32_chars
FRONTEND_URL=http://localhost:4200
NEXT_PUBLIC_API_URL=http://localhost:3000
UPLOAD_DIRECTORY=./uploads

# === GOOGLE (Drive + YouTube — misma OAuth app en Google Cloud Console) ===
# Crear en: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client ID
# Habilitar: Google Drive API y YouTube Data API v3
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback
YOUTUBE_CLIENT_ID=         # Mismo que GOOGLE_CLIENT_ID
YOUTUBE_CLIENT_SECRET=     # Mismo que GOOGLE_CLIENT_SECRET
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/integrations/youtube/callback
# OBTENER despues del OAuth: studio.youtube.com → icono de cuenta → ID del canal
YOUTUBE_CHANNEL_ID=

# === META (Facebook + Instagram — misma Meta Developer App) ===
# Crear en: developers.facebook.com → My Apps → Create App
# Agregar productos: Facebook Login, Instagram Basic Display
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/integrations/facebook/callback
# ID de tu pagina: facebook.com/pages → ajustes → informacion basica
FACEBOOK_PAGE_ID=
# Token largo: se genera automaticamente en el flow OAuth de la app
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/integrations/instagram/callback
# Instagram Business Account ID: developers.facebook.com → Graph API Explorer
INSTAGRAM_ACCOUNT_ID=

# === TIKTOK ===
# Crear en: developers.tiktok.com → My Apps
# Habilitar: Content Posting API, Login Kit
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/integrations/tiktok/callback

# === TWITTER / X ===
# Crear en: developer.twitter.com → Projects & Apps → New App
# Habilitar: OAuth 2.0, Read and Write permissions
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/integrations/twitter/callback

# === AI / LLM ===
# Anthropic Claude API key — used by competitor video analysis pipeline.
# Crear en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# === SEGURIDAD ===
# Contraseña para acceder a la aplicación web (leave blank to disable auth in dev)
APP_PASSWORD=tu-contraseña-segura-aqui
# Secret for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=cambia-esto-con-openssl-rand-hex-32
JWT_EXPIRY=7d
# Legacy session secret (no longer used)
SESSION_SECRET=cambia-esto-con-openssl-rand-hex-32
