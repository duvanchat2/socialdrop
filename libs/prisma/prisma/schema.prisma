generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  passwordHash String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  integrations Integration[]
  posts        Post[]
  driveConfigs DriveConfig[]
}

model Integration {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     Platform
  accountName  String?
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  profileId    String?
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  posts        PostIntegration[]

  @@unique([userId, platform, profileId])
  @@index([userId])
}

model Post {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String
  scheduledAt   DateTime
  publishedAt   DateTime?
  status        PostStatus        @default(DRAFT)
  errorMessage  String?
  retryCount    Int               @default(0)
  driveSourceId String?
  media         Media[]
  integrations  PostIntegration[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, status])
  @@index([scheduledAt, status])
}

model PostIntegration {
  id             String      @id @default(uuid())
  postId         String
  post           Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  integrationId  String
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  platformPostId String?
  status         PostStatus  @default(PENDING)
  errorMessage   String?
  publishedAt    DateTime?

  @@unique([postId, integrationId])
}

model Media {
  id          String    @id @default(uuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  url         String
  mimeType    String
  fileName    String
  fileSize    Int?
  mediaType   MediaType
  driveFileId String?
  createdAt   DateTime  @default(now())

  @@index([postId])
}

model DriveConfig {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId        String
  folderName      String?
  accessToken     String
  refreshToken    String
  tokenExpiry     DateTime?
  syncEnabled     Boolean   @default(true)
  lastSyncAt      DateTime?
  lastPageToken   String?
  pollingInterval Int       @default(300)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, folderId])
  @@index([userId])
}

enum Platform {
  INSTAGRAM
  TWITTER
  FACEBOOK
  TIKTOK
  LINKEDIN
  YOUTUBE
}

enum PostStatus {
  DRAFT
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  ERROR
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT
}

enum ContentType {
  SOCIAL
  YT_SHORT
  YT_LONG
}

enum Tone {
  CASUAL
  FORMAL
  FUNNY
  INSPIRATIONAL
}

model BrandProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  brandName      String   @default("")
  niche          String   @default("")
  tone           Tone     @default(CASUAL)
  alwaysUseWords String[]
  neverUseWords  String[]
  fixedHashtags  String[]
  optimalTimes   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model ContentStrategy {
  id         String   @id @default(uuid())
  userId     String   @unique
  dayConfigs Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model PlatformMetrics {
  id               String   @id @default(cuid())
  userId           String
  platform         String
  followersCount   Int
  followingCount   Int?
  postsCount       Int?
  reachTotal       Int?
  impressionsTotal Int?
  engagementRate   Float?
  recordedAt       DateTime @default(now())

  @@index([userId, platform])
  @@index([recordedAt])
}

model PostAnalytics {
  id             String    @id @default(cuid())
  postId         String?
  userId         String
  platform       String
  platformPostId String
  caption        String?
  mediaUrl       String?
  likes          Int       @default(0)
  comments       Int       @default(0)
  shares         Int       @default(0)
  saves          Int       @default(0)
  reach          Int       @default(0)
  impressions    Int       @default(0)
  views          Int       @default(0)
  engagementRate Float?
  publishedAt    DateTime?
  recordedAt     DateTime  @default(now())

  @@unique([userId, platform, platformPostId])
  @@index([userId, platform])
  @@index([recordedAt])
}

model ContentItem {
  id            String      @id @default(cuid())
  type          ContentType
  tema          String
  caption       String?
  hashtags      String[]
  title         String?
  tags          String[]
  thumbnailUrl  String?
  mediaDriveId  String?
  mediaUrl      String?
  platforms     Platform[]
  scheduledAt   DateTime?
  status        PostStatus  @default(DRAFT)
  copyGenerated Boolean     @default(false)
  n8nJobId      String?
  userId        String      @default("demo-user")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model GrowthGoal {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  metric    String
  target    Int
  deadline  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Competitor {
  id          String               @id @default(cuid())
  userId      String
  username    String
  platform    String
  displayName String?
  followers   Int?
  notes       String?
  createdAt   DateTime             @default(now())
  analyses    CompetitorAnalysis[]

  @@index([userId])
}

model CompetitorAnalysis {
  id              String     @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  summary         String
  hooks           String[]
  themes          String[]
  bestFormats     String[]
  recommendations String[]
  createdAt       DateTime   @default(now())
}

model QueueSlot {
  id        String   @id @default(cuid())
  userId    String
  platform  Platform
  dayOfWeek Int      // 0=Sunday … 6=Saturday
  hour      Int      // 0-23 local time
  minute    Int      // 0-59
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, platform])
  @@index([userId, dayOfWeek, hour, minute])
}

model Flow {
  id         String          @id @default(cuid())
  userId     String          @default("demo-user")
  name       String
  platform   String
  trigger    String
  keyword    String?
  isActive   Boolean         @default(true)
  nodes      Json            @default("[]")
  edges      Json            @default("[]")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  executions FlowExecution[]

  @@index([userId])
  @@index([userId, isActive])
}

model FlowExecution {
  id          String   @id @default(cuid())
  flowId      String
  flow        Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  triggeredBy String
  triggerType String
  status      String   @default("RUNNING")
  createdAt   DateTime @default(now())

  @@index([flowId])
  @@index([triggeredBy])
}

model Contact {
  id        String   @id @default(cuid())
  userId    String   @default("demo-user")
  platform  String
  accountId String
  username  String?
  name      String?
  tags      String[]
  createdAt DateTime @default(now())

  @@unique([platform, accountId])
  @@index([userId])
}
