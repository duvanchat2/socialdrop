generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  name                  String?
  passwordHash          String?
  emailVerifiedAt       DateTime?
  tokenVersion          Int               @default(0)
  lastActiveWorkspaceId String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  authTokens            AuthToken[]
  workspaceMemberships  WorkspaceMember[]
  usageCounters         UsageCounter[]
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

model Workspace {
  id               String            @id @default(uuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          WorkspaceMember[]
  integrations     Integration[]
  posts            Post[]
  driveConfigs     DriveConfig[]
  brandProfile     BrandProfile?
  contentStrategy  ContentStrategy?
  contentItems     ContentItem[]
  growthGoals      GrowthGoal[]
  competitors      Competitor[]
  queueSlots       QueueSlot[]
  flows            Flow[]
  contacts         Contact[]
  youtubeComments  YoutubeComment[]
  youtubeAutoReplies YoutubeAutoReply[]
  generatedScripts GeneratedScript[]
  contentBrain     ContentBrain?
  platformMetrics  PlatformMetrics[]
  postAnalytics    PostAnalytics[]
  postMetricSnapshots PostMetricSnapshot[]
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum AuthTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model UsageCounter {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric String
  /** "YYYY-MM" billing period */
  period String
  count  Int    @default(0)

  @@unique([userId, metric, period])
  @@index([userId, period])
}

model AuthToken {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String        @unique
  type      AuthTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId, type])
}

model Integration {
  id           String            @id @default(uuid())
  workspaceId  String
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform     Platform
  accountName  String?
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  profileId    String?
  metadata     Json?
  needsReauth  Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  posts        PostIntegration[]

  @@unique([workspaceId, platform, profileId])
  @@index([workspaceId])
}

model Post {
  id            String            @id @default(uuid())
  workspaceId   String
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content       String
  scheduledAt   DateTime
  publishedAt   DateTime?
  status        PostStatus        @default(DRAFT)
  errorMessage  String?
  retryCount    Int               @default(0)
  driveSourceId String?
  metadata      Json?
  media         Media[]
  integrations  PostIntegration[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([workspaceId, status])
  @@index([scheduledAt, status])
}

model PostIntegration {
  id             String      @id @default(uuid())
  postId         String
  post           Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  integrationId  String
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  platformPostId String?
  status         PostStatus  @default(PENDING)
  errorMessage   String?
  publishedAt    DateTime?

  @@unique([postId, integrationId])
}

model Media {
  id          String    @id @default(uuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  url         String
  mimeType    String
  fileName    String
  fileSize    Int?
  mediaType   MediaType
  driveFileId String?
  createdAt   DateTime  @default(now())

  @@index([postId])
}

model DriveConfig {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folderId        String
  folderName      String?
  accessToken     String
  refreshToken    String
  tokenExpiry     DateTime?
  syncEnabled     Boolean   @default(true)
  lastSyncAt      DateTime?
  lastPageToken   String?
  pollingInterval Int       @default(300)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([workspaceId, folderId])
  @@index([workspaceId])
}

enum Platform {
  INSTAGRAM
  TWITTER
  FACEBOOK
  TIKTOK
  LINKEDIN
  YOUTUBE
}

enum PostStatus {
  DRAFT
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  ERROR
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT
}

enum ContentType {
  SOCIAL
  YT_SHORT
  YT_LONG
}

enum Tone {
  CASUAL
  FORMAL
  FUNNY
  INSPIRATIONAL
}

model BrandProfile {
  id             String    @id @default(uuid())
  workspaceId    String    @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandName      String   @default("")
  niche          String   @default("")
  tone           Tone     @default(CASUAL)
  alwaysUseWords String[]
  neverUseWords  String[]
  fixedHashtags  String[]
  optimalTimes   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workspaceId])
}

model ContentStrategy {
  id          String    @id @default(uuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dayConfigs  Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model PlatformMetrics {
  id               String    @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform         String
  followersCount   Int
  followingCount   Int?
  postsCount       Int?
  reachTotal       Int?
  impressionsTotal Int?
  engagementRate   Float?
  recordedAt       DateTime @default(now())

  @@index([workspaceId, platform])
  @@index([recordedAt])
}

model PostAnalytics {
  id             String    @id @default(cuid())
  postId         String?
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform       String
  platformPostId String
  caption        String?
  mediaUrl       String?
  likes          Int       @default(0)
  comments       Int       @default(0)
  shares         Int       @default(0)
  saves          Int       @default(0)
  reach          Int       @default(0)
  impressions    Int       @default(0)
  views          Int       @default(0)
  engagementRate Float?
  publishedAt    DateTime?
  recordedAt     DateTime  @default(now())

  @@unique([workspaceId, platform, platformPostId])
  @@index([workspaceId, platform])
  @@index([recordedAt])
}

/// Append-only history of per-post metrics — one row per capture, never overwritten.
/// PostAnalytics stays as the "latest snapshot" view; this table is what powers time-series charts.
model PostMetricSnapshot {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform       String
  platformPostId String
  postId         String?
  likes          Int       @default(0)
  comments       Int       @default(0)
  shares         Int       @default(0)
  saves          Int       @default(0)
  reach          Int       @default(0)
  impressions    Int       @default(0)
  views          Int       @default(0)
  recordedAt     DateTime  @default(now())

  @@index([platformPostId, recordedAt])
  @@index([workspaceId])
}

model ContentItem {
  id            String      @id @default(cuid())
  type          ContentType
  tema          String
  caption       String?
  hashtags      String[]
  title         String?
  tags          String[]
  thumbnailUrl  String?
  mediaDriveId  String?
  mediaUrl      String?
  platforms     Platform[]
  scheduledAt   DateTime?
  status        PostStatus  @default(DRAFT)
  copyGenerated Boolean     @default(false)
  n8nJobId      String?
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([workspaceId])
}

model GrowthGoal {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform    String
  metric      String
  target      Int
  deadline    DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Competitor {
  id          String               @id @default(cuid())
  workspaceId String
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  username    String
  platform    String
  displayName String?
  followers   Int?
  following   Int?
  postsCount  Int?
  bio         String?
  avatar      String?
  isActive    Boolean              @default(true)
  notes       String?
  createdAt   DateTime             @default(now())
  analyses    CompetitorAnalysis[]
  posts       CompetitorPost[]

  @@unique([workspaceId, username, platform])
  @@index([workspaceId])
}

model CompetitorAnalysis {
  id              String     @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  summary         String
  hooks           String[]
  themes          String[]
  bestFormats     String[]
  recommendations String[]
  createdAt       DateTime   @default(now())
}

model CompetitorPost {
  id             String     @id @default(cuid())
  competitorId   String
  competitor     Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  postId         String     @unique
  url            String?
  thumbnail      String?
  caption        String?
  mediaType      String     @default("IMAGE")
  isReel         Boolean    @default(false)
  likes          Int        @default(0)
  comments       Int        @default(0)
  views          Int        @default(0)
  hashtags       String[]   @default([])
  publishedAt    DateTime?
  // ----- AI analysis (filled by competitor-analysis processor) -----
  transcript     String?
  hookText       String?
  hookType       String?
  whyItWorks     String?
  emotionTrigger String?
  keyTakeaway    String?
  analysisScore  Int?
  analyzedAt     DateTime?
  createdAt      DateTime   @default(now())

  @@index([competitorId])
  @@index([competitorId, publishedAt])
}

model QueueSlot {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform    Platform
  dayOfWeek   Int       // 0=Sunday … 6=Saturday
  hour        Int       // 0-23 local time
  minute      Int       // 0-59
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, platform])
  @@index([workspaceId, dayOfWeek, hour, minute])
}

model Flow {
  id         String          @id @default(cuid())
  workspaceId String
  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name       String
  platform   String
  trigger    String
  keyword    String?
  isActive   Boolean         @default(true)
  nodes      Json            @default("[]")
  edges      Json            @default("[]")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  executions FlowExecution[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model FlowExecution {
  id          String   @id @default(cuid())
  flowId      String
  flow        Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  triggeredBy String
  triggerType String
  status      String   @default("RUNNING")
  createdAt   DateTime @default(now())

  @@index([flowId])
  @@index([triggeredBy])
}

model Contact {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform    String
  accountId   String
  username    String?
  name        String?
  tags        String[]
  createdAt   DateTime  @default(now())

  @@unique([platform, accountId])
  @@index([workspaceId])
}

model YoutubeComment {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoId         String
  videoTitle      String?
  commentId       String    @unique
  authorName      String
  authorChannelId String?
  text            String
  likeCount       Int       @default(0)
  replyCount      Int       @default(0)
  publishedAt     DateTime?
  isShort         Boolean   @default(false)
  replied         Boolean   @default(false)
  repliedAt       DateTime?
  replyText       String?
  createdAt       DateTime  @default(now())

  @@index([workspaceId])
  @@index([workspaceId, replied])
  @@index([videoId])
}

model YoutubeAutoReply {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  keyword       String
  replyTemplate String
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([workspaceId])
}

model GeneratedScript {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform       String
  topic          String
  hook           String
  body           String
  cta            String?
  hashtags       String[]
  tone           String?
  contentType    String?   // SOCIAL | YT_SHORT | YT_LONG
  // Performance (populated 72h after publish)
  postId         String?
  likes          Int?
  saves          Int?
  reach          Int?
  follows        Int?
  engagementRate Float?
  isViral        Boolean   @default(false)
  metricsAt      DateTime?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, isViral])
  @@index([publishedAt])
}

model ContentBrain {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Learned patterns stored as JSON arrays
  viralHooks      Json     @default("[]")  // top performing hooks
  viralTopics     Json     @default("[]")  // recurring themes in viral posts
  viralFormats    Json     @default("[]")  // content formats that perform
  bestHashtags    Json     @default("[]")  // hashtags that boost reach
  optimalLength   Json     @default("{}")  // { platform: { hook: n, body: n } }
  // Stats
  totalScripts    Int      @default(0)
  viralCount      Int      @default(0)
  avgEngagement   Float?
  accuracyScore   Float?   // % of scripts that exceeded avg engagement
  lastLearnedAt   DateTime?
  nextLearnAt     DateTime?
  // Raw pattern text from Claude
  patternSummary  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workspaceId])
}
