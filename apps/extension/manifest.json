{
  "manifest_version": 3,
  "name": "SocialDrop Analyzer",
  "version": "1.0.0",
  "description": "Analyze Instagram competitors and sync to SocialDrop",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.instagram.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
