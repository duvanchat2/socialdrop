{
  "manifest_version": 3,
  "name": "SocialDrop Competitor Analyzer",
  "version": "1.0.0",
  "description": "Analiza perfiles de Instagram y sincroniza los datos con SocialDrop",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SocialDrop Analyzer"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
