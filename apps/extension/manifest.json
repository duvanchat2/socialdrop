{
  "manifest_version": 3,
  "name": "SocialDrop Analyzer",
  "version": "1.1.0",
  "description": "Analyze Instagram & TikTok competitors and sync to SocialDrop",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["panel.js", "instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["panel.js", "tiktok.js"],
      "run_at": "document_idle"
    }
  ]
}
